{
  "name": "panda",
  "version": "0.1.0",
  "description": "Panda AI assistant core and CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "panda": "./dist/app/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app/runtime": {
      "types": "./dist/app/runtime/index.d.ts",
      "import": "./dist/app/runtime/index.js"
    },
    "./kernel/agent": {
      "types": "./dist/kernel/agent/index.d.ts",
      "import": "./dist/kernel/agent/index.js"
    },
    "./panda": {
      "types": "./dist/panda/index.d.ts",
      "import": "./dist/panda/index.js"
    },
    "./domain/agents": {
      "types": "./dist/domain/agents/index.d.ts",
      "import": "./dist/domain/agents/index.js"
    },
    "./domain/identity": {
      "types": "./dist/domain/identity/index.d.ts",
      "import": "./dist/domain/identity/index.js"
    },
    "./domain/channels": {
      "types": "./dist/domain/channels/index.d.ts",
      "import": "./dist/domain/channels/index.js"
    },
    "./domain/channels/actions": {
      "types": "./dist/domain/channels/actions/index.d.ts",
      "import": "./dist/domain/channels/actions/index.js"
    },
    "./domain/channels/deliveries": {
      "types": "./dist/domain/channels/deliveries/index.d.ts",
      "import": "./dist/domain/channels/deliveries/index.js"
    },
    "./domain/threads": {
      "types": "./dist/domain/threads/index.d.ts",
      "import": "./dist/domain/threads/index.js"
    },
    "./domain/threads/requests": {
      "types": "./dist/domain/threads/requests/index.d.ts",
      "import": "./dist/domain/threads/requests/index.js"
    },
    "./domain/threads/runtime": {
      "types": "./dist/domain/threads/runtime/index.d.ts",
      "import": "./dist/domain/threads/runtime/index.js"
    },
    "./domain/scheduling": {
      "types": "./dist/domain/scheduling/index.d.ts",
      "import": "./dist/domain/scheduling/index.js"
    },
    "./domain/scheduling/tasks": {
      "types": "./dist/domain/scheduling/tasks/index.d.ts",
      "import": "./dist/domain/scheduling/tasks/index.js"
    },
    "./domain/watches": {
      "types": "./dist/domain/watches/index.d.ts",
      "import": "./dist/domain/watches/index.js"
    },
    "./integrations/shell": {
      "types": "./dist/integrations/shell/index.d.ts",
      "import": "./dist/integrations/shell/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/app/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/cli.js",
    "architecture:import-law": "node scripts/import-law-report.mjs",
    "architecture:import-law:ratchet": "node scripts/import-law-report.mjs --ratchet",
    "ci:test": "pnpm test",
    "ci:build": "pnpm build",
    "ci:architecture": "pnpm architecture:import-law:ratchet",
    "ci:prompt-contracts": "tsx scripts/ci/prompt-contracts.ts --check",
    "ci:control-ui": "pnpm control:typecheck && pnpm control:build",
    "ci:prompt-contracts:update": "tsx scripts/ci/prompt-contracts.ts --update",
    "ci:postgres-startup": "tsx scripts/ci/postgres-startup-rehearsal.ts",
    "ci:audit": "pnpm audit --audit-level high",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke": "tsx src/app/cli.ts smoke",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:live:watch": "vitest --config vitest.live.config.ts",
    "example:basic": "tsx examples/basic.ts",
    "example:structured": "tsx examples/structured-output.ts",
    "control:dev": "pnpm --filter control-ui dev",
    "control:build": "pnpm --filter control-ui build",
    "control:typecheck": "pnpm --filter control-ui typecheck"
  },
  "keywords": [
    "ai",
    "assistant",
    "openai",
    "agents",
    "panda"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "overrides": {
    "@anthropic-ai/sdk": "0.91.1",
    "protobufjs": "7.6.1",
    "hono": "4.12.25",
    "basic-ftp": "5.3.1",
    "fast-xml-builder": "1.1.7",
    "nodemailer": "9.0.1"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.1",
    "@mozilla/readability": "^0.6.0",
    "abort-controller": "^3.0.0",
    "baileys": "7.0.0-rc12",
    "commander": "^14.0.3",
    "grammy": "^1.42.0",
    "imapflow": "^1.3.2",
    "ipaddr.js": "^2.3.0",
    "linkedom": "^0.18.12",
    "mailparser": "^3.9.8",
    "marked": "^18.0.2",
    "mongodb": "^7.2.0",
    "mysql2": "^3.22.2",
    "nodemailer": "9.0.1",
    "pg": "^8.20.0",
    "playwright-core": "^1.59.1",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "pg-mem": "^3.0.14",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
