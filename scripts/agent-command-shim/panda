#!/usr/bin/env bash
set -euo pipefail

base_url="${PANDA_COMMAND_URL:-}"
socket_path="${PANDA_COMMAND_SOCKET:-}"
token="${PANDA_COMMAND_TOKEN:-}"
shim_dir="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

die() {
  printf '%s\n' "$1" >&2
  exit 1
}

source_generated_routes() {
  local candidate
  for candidate in \
    "${PANDA_COMMAND_SHIM_ROUTES_FILE:-}" \
    "${shim_dir}/routes.generated.sh" \
    "/usr/local/lib/panda-agent-command-shim/routes.generated.sh"
  do
    [ -n "$candidate" ] || continue
    [ -f "$candidate" ] || continue
    # shellcheck source=/dev/null
    . "$candidate"
    return 0
  done

  return 0
}

source_generated_routes

read_access_file_value() {
  local key="$1"
  local file="$2"
  sed -n "s/^${key}=//p" "$file" | tail -n 1
}

load_command_access_file() {
  local file="${PANDA_COMMAND_ACCESS_FILE:-}"
  [ -n "$file" ] || return 0
  [ -f "$file" ] || return 0

  local file_base_url file_token
  local file_socket_path
  file_base_url="$(read_access_file_value "PANDA_COMMAND_URL" "$file")"
  file_socket_path="$(read_access_file_value "PANDA_COMMAND_SOCKET" "$file")"
  file_token="$(read_access_file_value "PANDA_COMMAND_TOKEN" "$file")"
  base_url="$file_base_url"
  socket_path="$file_socket_path"
  token="$file_token"
}

agent_command_shim_has_command_access() {
  load_command_access_file
  { [ -n "$base_url" ] || [ -n "$socket_path" ]; } && [ -n "$token" ]
}

require_transport() {
  load_command_access_file
  [ -n "$base_url" ] || [ -n "$socket_path" ] || die "Panda command execution needs agent command access. Run this inside an agent bash call, or provide PANDA_COMMAND_ACCESS_FILE/PANDA_COMMAND_URL/PANDA_COMMAND_SOCKET with a valid lease token. Help commands still work without transport when local generated routes are installed."
  [ -n "$token" ] || die "Panda command execution needs PANDA_COMMAND_TOKEN or a PANDA_COMMAND_ACCESS_FILE containing a valid lease token."
}

command_url() {
  load_command_access_file
  local path="$1"
  if [ -n "$socket_path" ]; then
    printf 'http://panda-command/%s' "${path#/}"
    return
  fi
  printf '%s/%s' "${base_url%/}" "${path#/}"
}

allow_sigpipe() {
  local status
  set +e
  "$@"
  status=$?
  set -e
  case "$status" in
    0|141)
      return 0
      ;;
    *)
      return "$status"
      ;;
  esac
}

curl_command_to_file() {
  local output="$1"
  shift
  require_transport
  if [ -n "$socket_path" ]; then
    curl -fsS --unix-socket "$socket_path" -H "authorization: Bearer ${token}" --output "$output" "$@"
    return
  fi
  curl -fsS -H "authorization: Bearer ${token}" --output "$output" "$@"
}

curl_command() {
  local tmp status
  tmp="$(mktemp "${TMPDIR:-/tmp}/panda-command.XXXXXX")"
  set +e
  curl_command_to_file "$tmp" "$@"
  status=$?
  set -e
  if [ "$status" -ne 0 ]; then
    rm -f "$tmp"
    return "$status"
  fi

  printf '\n' >> "$tmp"
  allow_sigpipe cat "$tmp"
  status=$?
  rm -f "$tmp"
  return "$status"
}

curl_command_raw() {
  require_transport
  if [ -n "$socket_path" ]; then
    curl -sS --unix-socket "$socket_path" -H "authorization: Bearer ${token}" "$@"
    return
  fi
  curl -sS -H "authorization: Bearer ${token}" "$@"
}

print_command_failure_envelope() {
  local response="$1"
  if ! printf '%s' "$response" | jq -e '.ok == false and (.error | type) == "object" and (.error.code | type) == "string"' >/dev/null 2>&1; then
    printf '%s\n' "$response" >&2
    return 1
  fi
  printf '%s' "$response" | jq -c 'if .command == null then {ok: false, error} else {ok: false, command, error} end' >&2
}

command_failure_exit_code() {
  local response="$1"
  printf '%s' "$response" | jq -r '
    .error.details.exitCode
    | if type == "number" and floor == . and . >= 1 and . <= 125 then . else 1 end
  ' 2>/dev/null || printf '1\n'
}

read_json_input() {
  local value="$1"
  case "$value" in
    @-)
      cat
      ;;
    @*)
      cat "${value#@}"
      ;;
    *)
      printf '%s' "$value"
      ;;
  esac
}

read_text_input() {
  local value="$1"
  case "$value" in
    @-)
      cat
      ;;
    @*)
      cat "${value#@}"
      ;;
    *)
      printf '%s' "$value"
      ;;
  esac
}

read_text_input_json() {
  read_text_input "$1" | jq -Rs .
}

upload_a2a_file() {
  local file_path="$1"
  local filename response
  [ -f "$file_path" ] && [ -r "$file_path" ] || die "panda a2a send --file requires a readable client-local file."
  filename="$(basename -- "$file_path" | tr -d '\r\n')"
  response="$(curl_command_raw \
    -H "content-type: application/octet-stream" \
    -H "x-panda-filename: ${filename}" \
    -X POST \
    --data-binary "@${file_path}" \
    "$(command_url "/commands/files?for=a2a.send")")" || die "panda a2a file upload failed."
  if ! printf '%s' "$response" | jq -e '.uploadRef | type == "string"' >/dev/null 2>&1; then
    printf '%s\n' "$response" | jq -r '.error // "panda a2a file upload failed."' >&2 2>/dev/null || true
    return 1
  fi
  printf '%s' "$response"
}

require_positive_integer() {
  local value="$1"
  local label="$2"
  case "$value" in
    ''|*[!0-9]*)
      die "$label requires a positive integer."
      ;;
  esac
  [ "$value" -gt 0 ] || die "$label requires a positive integer."
}

require_positive_number() {
  local value="$1"
  local label="$2"
  if ! printf '%s' "$value" | jq -e 'type == "number" and . > 0' >/dev/null 2>&1; then
    die "$label requires a positive number."
  fi
}

build_http_json_scalar_watch_source() {
  local url="$1"
  local value_path="$2"
  local label="$3"
  local label_set="$4"
  jq -n \
    --arg url "$url" \
    --arg valuePath "$value_path" \
    --arg label "$label" \
    --arg labelSet "$label_set" \
    '{kind: "http_json", url: $url, result: ({observation: "scalar", valuePath: $valuePath} + (if $labelSet == "true" then {label: $label} else {} end))}'
}

build_percent_change_watch_detector() {
  local percent="$1"
  jq -n \
    --arg percent "$percent" \
    '{kind: "percent_change", percent: ($percent | tonumber)}'
}

require_non_negative_integer() {
  local value="$1"
  local label="$2"
  case "$value" in
    ''|*[!0-9]*)
      die "$label requires a non-negative integer."
      ;;
  esac
}

read_json_object_input() {
  local value="$1"
  local label="$2"
  local json_value
  json_value="$(read_json_input "$value")"
  printf '%s' "$json_value" | jq -e 'type == "object"' >/dev/null || die "$label must be a JSON object."
  printf '%s' "$json_value"
}

validate_json_kind() {
  local label="$1"
  local expected="$2"
  local payload="$3"
  [ -n "$expected" ] || return 0
  local actual
  actual="$(printf '%s' "$payload" | jq -er '.kind // empty')" || die "$label JSON must include kind when --${label}-kind is provided."
  [ "$actual" = "$expected" ] || die "$label JSON kind '$actual' does not match --${label}-kind '$expected'."
}

execute_json_command() {
  local command="$1"
  local input="$2"
  local body response status ok exit_code
  body="$(jq -n --arg command "$command" --arg cwd "$PWD" --argjson input "$input" '{command: $command, input: $input, outputMode: "json", workingDirectory: $cwd}')"
  set +e
  response="$(curl_command_raw -H "content-type: application/json" -X POST --data "$body" "$(command_url "/commands/execute")")"
  status=$?
  set -e
  if [ "$status" -ne 0 ]; then
    [ -z "$response" ] || printf '%s\n' "$response" >&2
    return "$status"
  fi

  ok="$(printf '%s' "$response" | jq -r '.ok // empty')" || {
    printf '%s\n' "$response" >&2
    return 1
  }
  if [ "$ok" = "true" ]; then
    allow_sigpipe jq -c 'if (.artifact and (.output | type) == "object") then (.output + {artifact: .artifact}) else .output end' <<<"$response"
    return 0
  fi

  print_command_failure_envelope "$response" || return 1
  exit_code="$(command_failure_exit_code "$response")"
  return "$exit_code"
}

project_skill_list_output() {
  local output="$1"
  local response="$2"
  case "$output" in
    keys)
      allow_sigpipe jq -r '.skills[]?.skillKey' <<<"$response"
      ;;
    json)
      allow_sigpipe jq -c '.' <<<"$response"
      ;;
    table)
      allow_sigpipe jq -r '
        ["SKILL KEY", "DESCRIPTION", "TAGS", "CONTENT BYTES"],
        (.skills[] | [.skillKey, .description, (.tags | join(",")), (.contentBytes | tostring)])
        | @tsv
      ' <<<"$response"
      ;;
  esac
}

project_command_catalog_output() {
  local output="$1"
  local response="$2"
  case "$output" in
    keys)
      allow_sigpipe jq -r '.commands[]?.name' <<<"$response"
      ;;
    json)
      allow_sigpipe jq -c '.' <<<"$response"
      ;;
    table)
      allow_sigpipe jq -r '
        ["COMMAND", "SUMMARY", "INPUT MODES", "OUTPUT MODES"],
        (.commands[] | [.name, .summary, (.inputModes | join(",")), (.outputModes | join(","))])
        | @tsv
      ' <<<"$response"
      ;;
  esac
}


mcp_input_error() {
  printf '%s\n' "$1" >&2
  return 2
}


mcp_require_positive_integer() {
  local value="$1"
  local label="$2"
  case "$value" in
    ''|*[!0-9]*)
      mcp_input_error "$label requires a positive integer."
      return 2
      ;;
  esac
  if [ "$value" -le 0 ]; then
    mcp_input_error "$label requires a positive integer."
    return 2
  fi
}

read_mcp_json_object_input() {
  local value="$1"
  local label="$2"
  local json_value
  if ! json_value="$(read_json_input "$value")"; then
    mcp_input_error "$label could not be read."
    return 2
  fi
  if ! printf '%s' "$json_value" | jq -e 'type == "object"' >/dev/null 2>&1; then
    mcp_input_error "$label must be a JSON object."
    return 2
  fi
  printf '%s' "$json_value"
}

mcp_execute_json_command() {
  local command="$1"
  local input="$2"
  local body response status ok exit_code
  body="$(jq -n --arg command "$command" --arg cwd "$PWD" --argjson input "$input" '{command: $command, input: $input, outputMode: "json", workingDirectory: $cwd}')"
  set +e
  response="$(curl_command_raw -H "content-type: application/json" -X POST --data "$body" "$(command_url "/commands/execute")")"
  status=$?
  set -e
  if [ "$status" -ne 0 ]; then
    [ -z "$response" ] || printf '%s\n' "$response" >&2
    return "$status"
  fi

  ok="$(printf '%s' "$response" | jq -r '.ok // empty')" || {
    printf '%s\n' "$response" >&2
    return 1
  }
  if [ "$ok" = "true" ]; then
    allow_sigpipe jq -c 'if (.artifact and (.output | type) == "object") then (.output + {artifact: .artifact}) else .output end' <<<"$response"
    exit_code="$(printf '%s' "$response" | jq -r 'if .output.exitCode != null then .output.exitCode elif .output.isError == true then 4 else 0 end')" || return 1
    return "$exit_code"
  fi

  print_command_failure_envelope "$response" || return 1
  exit_code="$(command_failure_exit_code "$response")"
  return "$exit_code"
}

execute_audio_file_command() {
  local command_name="$1"
  local command_label="$2"
  local allow_language="$3"
  shift 3
  if [ "${1:-}" = "--help" ]; then
    shift
    if [ "${1:-}" = "--json" ]; then
      curl_command "$(command_url "/commands/${command_name}/help?format=json")"
      return 0
    fi
    curl_command "$(command_url "/commands/${command_name}/help")"
    return 0
  fi
  if [ "${1:-}" = "--json" ]; then
    shift
    [ -n "${1:-}" ] || die "panda ${command_label} --json requires @file, @-, or inline JSON."
    execute_json_command "$command_name" "$(read_json_input "$1")"
    return $?
  fi

  local audio_path language prompt option payload
  audio_path="${1:-}"
  [ -n "$audio_path" ] || die "panda ${command_label} requires <path> or --json @payload.json."
  shift
  language=""
  prompt=""
  while [ "$#" -gt 0 ]; do
    option="$1"
    shift
    case "$option" in
      --language)
        [ "$allow_language" = "true" ] || die "panda ${command_label} does not accept --language; translations target English."
        [ "$#" -gt 0 ] || die "panda ${command_label} --language requires a value."
        language="$1"
        shift
        ;;
      --prompt)
        [ "$#" -gt 0 ] || die "panda ${command_label} --prompt requires a value."
        prompt="$(read_text_input "$1")"
        shift
        ;;
      *)
        die "Unknown panda ${command_label} option: $option"
        ;;
    esac
  done
  payload="$(jq -n \
    --arg path "$audio_path" \
    --arg language "$language" \
    --arg prompt "$prompt" \
    '({path: $path})
     + (if $language != "" then {language: $language} else {} end)
     + (if $prompt != "" then {prompt: $prompt} else {} end)')"
  execute_json_command "$command_name" "$payload"
}

parse_duration_minutes() {
  local value="$1"
  local label="$2"
  local number
  case "$value" in
    *m)
      number="${value%m}"
      require_positive_integer "$number" "$label"
      printf '%s' "$number"
      ;;
    *h)
      number="${value%h}"
      require_positive_integer "$number" "$label"
      printf '%s' "$((number * 60))"
      ;;
    *)
      require_positive_integer "$value" "$label"
      printf '%s' "$value"
      ;;
  esac
}

parse_duration_hours() {
  local value="$1"
  local label="$2"
  local number
  case "$value" in
    *h)
      number="${value%h}"
      require_positive_integer "$number" "$label"
      printf '%s' "$number"
      ;;
    *)
      require_positive_integer "$value" "$label"
      printf '%s' "$value"
      ;;
  esac
}

print_micro_app_group_help() {
  local root_label="$1"
  cat <<USAGE
Usage:
  panda ${root_label} check --help [--json]
  panda ${root_label} create --help [--json]
  panda ${root_label} link create --help [--json]
  panda ${root_label} list --help [--json]
  panda ${root_label} view --help [--json]
  panda ${root_label} action --help [--json]
  panda ${root_label} check [app-slug]
  panda ${root_label} create <slug> --name <text|@file|@-> [--description <text|@file|@->] [--identity-scoped] [--schema <sql|@file|@->]
  panda ${root_label} link create <app-slug> [--expires <minutes|Nm|Nh>]
  panda ${root_label} list [app-slug] [--full]
  panda ${root_label} view <app-slug> <view-name> [--param key=value] [--params <json|@file|@->] [--page-size <n>] [--offset <n>]
  panda ${root_label} action <app-slug> <action-name> [--input <json|@file|@->]
  panda ${root_label} check --json @payload.json
  panda ${root_label} create --json @payload.json
  panda ${root_label} link create --json @payload.json
  panda ${root_label} list --json @payload.json
  panda ${root_label} view --json @payload.json
  panda ${root_label} action --json @payload.json
USAGE
}

execute_micro_app_cli() {
  local root_label="$1"
  shift
  case "${1:-}" in
    ""|--help|-h)
      print_micro_app_group_help "$root_label"
      return 0
      ;;
  esac

  local subcommand command_name command_label
  subcommand="${1:-}"
  command_label="$subcommand"
  case "$subcommand" in
    check) command_name="micro-app.check" ;;
    create) command_name="micro-app.create" ;;
    list) command_name="micro-app.list" ;;
    view) command_name="micro-app.view" ;;
    action) command_name="micro-app.action" ;;
    link)
      shift
      [ "${1:-}" = "create" ] || die "Unknown panda ${root_label} link command. Try: panda ${root_label} link create --help"
      command_name="micro-app.link.create"
      command_label="link create"
      ;;
    *) die "Unknown panda ${root_label} command. Try: panda ${root_label} list --help" ;;
  esac
  shift

  if [ "${1:-}" = "--help" ]; then
    shift
    if [ "${1:-}" = "--json" ]; then
      curl_command "$(command_url "/commands/${command_name}/help?format=json")"
      return 0
    fi
    curl_command "$(command_url "/commands/${command_name}/help")"
    return 0
  fi
  if [ "${1:-}" = "--json" ]; then
    shift
    [ -n "${1:-}" ] || die "panda ${root_label} ${command_label} --json requires @file, @-, or inline JSON."
    execute_json_command "$command_name" "$(read_json_input "$1")"
    return $?
  fi

  local app_slug detail payload
  case "$command_name" in
    micro-app.check)
      app_slug="${1:-}"
      if [ -n "$app_slug" ]; then
        case "$app_slug" in
          --*) die "Unknown panda ${root_label} check option: $app_slug" ;;
        esac
        shift
      fi
      [ "$#" -eq 0 ] || die "panda ${root_label} check accepts at most one app slug."
      if [ -n "$app_slug" ]; then
        payload="$(jq -n --arg appSlug "$app_slug" '{appSlug: $appSlug}')"
      else
        payload="{}"
      fi
      execute_json_command "$command_name" "$payload"
      return $?
      ;;
    micro-app.list)
      app_slug=""
      detail=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --full)
            detail="full"
            shift
            ;;
          --summary)
            detail="summary"
            shift
            ;;
          --detail)
            [ "$#" -gt 1 ] || die "panda ${root_label} list --detail requires summary or full."
            case "$2" in
              summary|full) detail="$2" ;;
              *) die "panda ${root_label} list --detail requires summary or full." ;;
            esac
            shift 2
            ;;
          --*)
            die "Unknown panda ${root_label} list option: $1"
            ;;
          *)
            [ -z "$app_slug" ] || die "panda ${root_label} list accepts at most one app slug."
            app_slug="$1"
            shift
            ;;
        esac
      done
      if [ "$detail" = "full" ] && [ -z "$app_slug" ]; then
        die "panda ${root_label} list --full requires <app-slug>."
      fi
      payload="$(jq -n \
        --arg appSlug "$app_slug" \
        --arg detail "$detail" \
        '{}
         + (if $appSlug != "" then {appSlug: $appSlug} else {} end)
         + (if $detail != "" then {detail: $detail} else {} end)')"
      execute_json_command "$command_name" "$payload"
      return $?
      ;;
    micro-app.create)
      app_slug="${1:-}"
      [ -n "$app_slug" ] || die "panda ${root_label} create requires <slug>."
      case "$app_slug" in
        --*) die "panda ${root_label} create requires <slug> before options." ;;
      esac
      shift
      local app_name description identity_scoped schema_sql
      app_name=""
      description=""
      identity_scoped="false"
      schema_sql=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --name)
            [ "$#" -gt 1 ] || die "panda ${root_label} create --name requires a value."
            app_name="$(read_text_input "$2")"
            shift 2
            ;;
          --description)
            [ "$#" -gt 1 ] || die "panda ${root_label} create --description requires a value."
            description="$(read_text_input "$2")"
            shift 2
            ;;
          --identity-scoped)
            identity_scoped="true"
            shift
            ;;
          --schema|--schema-sql)
            [ "$#" -gt 1 ] || die "panda ${root_label} create $1 requires a value."
            schema_sql="$(read_text_input "$2")"
            shift 2
            ;;
          --*)
            die "Unknown panda ${root_label} create option: $1"
            ;;
          *)
            die "Unexpected panda ${root_label} create argument: $1"
            ;;
        esac
      done
      [ -n "$app_name" ] || die "panda ${root_label} create requires --name <text|@file|@->."
      payload="$(jq -n \
        --arg slug "$app_slug" \
        --arg name "$app_name" \
        --arg description "$description" \
        --arg schemaSql "$schema_sql" \
        --argjson identityScoped "$identity_scoped" \
        '{
          slug: $slug,
          name: $name
        }
        + (if $description != "" then {description: $description} else {} end)
        + (if $identityScoped then {identityScoped: true} else {} end)
        + (if $schemaSql != "" then {schemaSql: $schemaSql} else {} end)')"
      execute_json_command "$command_name" "$payload"
      return $?
      ;;
    micro-app.link.create)
      app_slug="${1:-}"
      [ -n "$app_slug" ] || die "panda ${root_label} link create requires <app-slug>."
      case "$app_slug" in
        --*) die "panda ${root_label} link create requires <app-slug> before options." ;;
      esac
      shift
      local expires_minutes
      expires_minutes=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --expires)
            [ "$#" -gt 1 ] || die "panda ${root_label} link create --expires requires minutes, Nm, or Nh."
            expires_minutes="$(parse_duration_minutes "$2" "panda ${root_label} link create --expires")"
            shift 2
            ;;
          --expires-minutes)
            [ "$#" -gt 1 ] || die "panda ${root_label} link create --expires-minutes requires a value."
            require_positive_integer "$2" "panda ${root_label} link create --expires-minutes"
            expires_minutes="$2"
            shift 2
            ;;
          --*)
            die "Unknown panda ${root_label} link create option: $1"
            ;;
          *)
            die "Unexpected panda ${root_label} link create argument: $1"
            ;;
        esac
      done
      payload="$(jq -n \
        --arg appSlug "$app_slug" \
        --arg expiresInMinutes "$expires_minutes" \
        '{appSlug: $appSlug}
         + (if $expiresInMinutes != "" then {expiresInMinutes: ($expiresInMinutes | tonumber)} else {} end)')"
      execute_json_command "$command_name" "$payload"
      return $?
      ;;
    micro-app.view)
      app_slug="${1:-}"
      [ -n "$app_slug" ] || die "panda ${root_label} view requires <app-slug> <view-name>."
      case "$app_slug" in
        --*) die "panda ${root_label} view requires <app-slug> before options." ;;
      esac
      shift
      local view_name params_json page_size offset key_value param_key param_value next_params
      view_name="${1:-}"
      [ -n "$view_name" ] || die "panda ${root_label} view requires <view-name>."
      case "$view_name" in
        --*) die "panda ${root_label} view requires <view-name> before options." ;;
      esac
      shift
      params_json="{}"
      page_size=""
      offset=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --params)
            [ "$#" -gt 1 ] || die "panda ${root_label} view --params requires a JSON object, @file, or @-."
            next_params="$(read_json_object_input "$2" "panda ${root_label} view --params")"
            params_json="$(jq -cn --argjson current "$params_json" --argjson next "$next_params" '$current + $next')"
            shift 2
            ;;
          --param)
            [ "$#" -gt 1 ] || die "panda ${root_label} view --param requires key=value."
            key_value="$2"
            case "$key_value" in
              *=*)
                param_key="${key_value%%=*}"
                param_value="${key_value#*=}"
                [ -n "$param_key" ] || die "panda ${root_label} view --param requires a non-empty key."
                params_json="$(printf '%s' "$params_json" | jq -c --arg key "$param_key" --arg value "$param_value" '. + {($key): $value}')"
                ;;
              *)
                die "panda ${root_label} view --param requires key=value."
                ;;
            esac
            shift 2
            ;;
          --page-size)
            [ "$#" -gt 1 ] || die "panda ${root_label} view --page-size requires a number."
            require_positive_integer "$2" "panda ${root_label} view --page-size"
            page_size="$2"
            shift 2
            ;;
          --offset)
            [ "$#" -gt 1 ] || die "panda ${root_label} view --offset requires a number."
            require_non_negative_integer "$2" "panda ${root_label} view --offset"
            offset="$2"
            shift 2
            ;;
          --*)
            die "Unknown panda ${root_label} view option: $1"
            ;;
          *)
            die "Unexpected panda ${root_label} view argument: $1"
            ;;
        esac
      done
      payload="$(jq -n \
        --arg appSlug "$app_slug" \
        --arg viewName "$view_name" \
        --argjson params "$params_json" \
        --arg pageSize "$page_size" \
        --arg offset "$offset" \
        '{
          appSlug: $appSlug,
          viewName: $viewName
        }
        + (if ($params | length) > 0 then {params: $params} else {} end)
        + (if $pageSize != "" then {pageSize: ($pageSize | tonumber)} else {} end)
        + (if $offset != "" then {offset: ($offset | tonumber)} else {} end)')"
      execute_json_command "$command_name" "$payload"
      return $?
      ;;
    micro-app.action)
      app_slug="${1:-}"
      [ -n "$app_slug" ] || die "panda ${root_label} action requires <app-slug> <action-name>."
      case "$app_slug" in
        --*) die "panda ${root_label} action requires <app-slug> before options." ;;
      esac
