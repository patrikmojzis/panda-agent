      input_json="{}"
      input_seen="false"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --input)
            [ "$#" -gt 1 ] || die "panda ${root_label} action --input requires a JSON object, @file, or @-."
            input_json="$(read_json_object_input "$2" "panda ${root_label} action --input")"
            input_seen="true"
            shift 2
            ;;
          --*)
            die "Unknown panda ${root_label} action option: $1"
            ;;
          *)
            die "Unexpected panda ${root_label} action argument: $1"
            ;;
        esac
      done
      payload="$(jq -n \
        --arg appSlug "$app_slug" \
        --arg actionName "$action_name" \
        --argjson input "$input_json" \
        --argjson inputSeen "$input_seen" \
        '{
          appSlug: $appSlug,
          actionName: $actionName
        }
        + (if $inputSeen then {input: $input} else {} end)')"
      execute_json_command "$command_name" "$payload"
      return $?
      ;;
    *)
      die "panda ${root_label} ${command_label} requires --json @file or --json @-."
      ;;
  esac
}

generated_route_prefix() {
  local length="$1"
  shift
  local args=("$@")
  local prefix="${args[0]}"
  local index
  for ((index = 1; index < length; index += 1)); do
    prefix="${prefix} ${args[$index]}"
  done
  printf '%s' "$prefix"
}

dispatch_generated_json_route() {
  declare -F agent_command_shim_lookup_route >/dev/null || return 127

  local args=("$@")
  local length prefix route command_name command_label
  for length in 4 3 2 1; do
    [ "${#args[@]}" -ge "$length" ] || continue
    prefix="$(generated_route_prefix "$length" "${args[@]}")"
    if route="$(agent_command_shim_lookup_route "$prefix")"; then
      IFS=$'\t' read -r command_name command_label <<<"$route"
      local rest=("${args[@]:$length}")
      if [ "${rest[0]:-}" = "--help" ]; then
        if [ "${rest[1]:-}" = "--json" ]; then
          if declare -F agent_command_shim_print_local_help_json >/dev/null; then
            if agent_command_shim_print_local_help_json "$command_name"; then
              return 0
            fi
          fi
          if curl_command "$(command_url "/commands/${command_name}/help?format=json")"; then
            return 0
          fi
          return $?
        fi
        if declare -F agent_command_shim_print_local_help >/dev/null; then
          if agent_command_shim_print_local_help "$command_name"; then
            return 0
          fi
        fi
        if curl_command "$(command_url "/commands/${command_name}/help")"; then
          return 0
        fi
        return $?
      fi
      [ "$command_name" != "skill.list" ] || return 127
      if [ "${rest[0]:-}" = "--json" ]; then
        [ -n "${rest[1]:-}" ] || die "panda ${command_label} --json requires @file, @-, or inline JSON."
        local json_payload
        json_payload="$(read_json_input "${rest[1]}")"
        if [ "$command_name" = "web.fetch" ] && printf '%s' "$json_payload" | jq -e 'type == "object" and (has("maxContentChars") or has("maxChars") or has("max_chars"))' >/dev/null; then
          die "panda web fetch maxContentChars was removed; use chunkChars."
        fi
        execute_json_command "$command_name" "$json_payload"
        return $?
      fi
      return 127
    fi
  done

  return 127
}

if [ "$#" -gt 0 ]; then
  set +e
  dispatch_generated_json_route "$@"
  generated_status=$?
  set -e
  if [ "$generated_status" -ne 127 ]; then
    exit "$generated_status"
  fi
fi

