# Core runtime
DATABASE_URL=postgresql:///panda_dev
# Required for stored credentials and encrypted wiki bindings.
CREDENTIALS_MASTER_KEY=
# Optional read-only connection for the SQL inspection tool.
READONLY_DATABASE_URL=
# Docker stack helper. Comma-separated agent keys for per-agent bash runners.
PANDA_AGENTS=
# Docker stack helper. Agent calendars auto-enable when PANDA_AGENTS is set; set false to skip Radicale.
PANDA_CALENDAR_ENABLED=
# Calendar collection name created for each agent.
PANDA_CALENDAR_NAME=calendar
# panda-core only. Docker stack fills these automatically when Radicale is enabled.
PANDA_CALENDAR_URL=
PANDA_CALENDAR_USERS_FILE=
# Optional Radicale Docker overrides.
PANDA_RADICALE_IMAGE=
PANDA_RADICALE_UID=
PANDA_RADICALE_GID=
PANDA_RADICALE_TAKE_FILE_OWNERSHIP=
# Optional host path overrides for the docker stack helper.
SHARED_ROOT=
BROWSER_RUNNER_ROOT=
# Optional host path to a Codex home directory with auth.json.
# Useful when Docker should use a non-default host login like /home/username/.codex.
CODEX_HOST_HOME=
# Optional runtime timezone for Panda Docker services.
TZ=UTC
# Optional app host base URLs.
PANDA_APPS_HOST=
PANDA_APPS_PORT=
PANDA_APPS_BASE_URL=
PANDA_APPS_INTERNAL_BASE_URL=
# Optional public gateway edge for the docker stack. Requires HTTPS via Caddy.
PANDA_GATEWAY_ENABLED=
PANDA_GATEWAY_BASE_URL=
PANDA_GATEWAY_PUBLIC_HOST=
PANDA_GATEWAY_EDGE_SUBNET=172.31.94.0/24

# Gateway ingress
# Public server-to-server REST ingress. Leave host at 127.0.0.1 for local-only runs.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8094
# Required when binding gateway to a public host like 0.0.0.0. Comma-separated IPs or CIDRs.
GATEWAY_IP_ALLOWLIST=
# Set only to trusted reverse proxy IPs/CIDRs. The proxy must strip incoming X-Forwarded-For.
GATEWAY_TRUSTED_PROXY_IPS=
# Explicit unsafe escape hatch for public binds without an IP allowlist. Do not use in production.
GATEWAY_ALLOW_PUBLIC_WITHOUT_IP_ALLOWLIST=
# Required by `panda gateway run`.
GATEWAY_GUARD_MODEL=
# Optional tuning.
GATEWAY_GUARD_TIMEOUT_MS=
GATEWAY_ACCESS_TOKEN_TTL_MS=
GATEWAY_MAX_ACTIVE_TOKENS_PER_SOURCE=
GATEWAY_MAX_TEXT_BYTES=
GATEWAY_RATE_LIMIT_PER_MINUTE=
GATEWAY_TEXT_BYTES_PER_HOUR=

# Telepathy / Mac receiver bridge
# panda-core only. For the Docker stack, set TELEPATHY_ENABLED=true and TELEPATHY_PORT=8787 together.
TELEPATHY_ENABLED=
# panda-core only. Inside Docker this should stay 0.0.0.0 so the host publish can reach it.
TELEPATHY_HOST=0.0.0.0
# panda-core only. Leave empty to keep telepathy off, or set a port like 8787.
TELEPATHY_PORT=
# panda-core only.
TELEPATHY_PATH=/telepathy

# Bash execution
# Default is `local`. Set to `remote` in panda-core when bash should run through per-agent runners.
BASH_EXECUTION_MODE=local
# panda-core only. Use `{agentKey}` for per-agent routing, or a plain URL for a single shared runner.
RUNNER_URL_TEMPLATE=
# panda-core only. Optional initial cwd for remote-mode threads before the first bash call.
# Use `{agentKey}` for per-agent homes, for example `/root/.panda/agents/{agentKey}`.
RUNNER_CWD_TEMPLATE=
# runner only. The runner serves exactly one agent.
RUNNER_AGENT_KEY=
# runner only. Additional allowed roots separated by your OS path delimiter (`:` on macOS/Linux).
RUNNER_ALLOWED_ROOTS=
# runner only.
RUNNER_PORT=8080
RUNNER_HOST=0.0.0.0

# Browser execution
# panda-core only. URL for the isolated browser-runner service.
BROWSER_RUNNER_URL=
# Shared bearer token used between panda-core and browser-runner.
BROWSER_RUNNER_SHARED_SECRET=
# browser-runner only.
BROWSER_RUNNER_PORT=8080
BROWSER_RUNNER_HOST=0.0.0.0
# browser-runner only. Durable session state and scratch artifact root.
BROWSER_RUNNER_DATA_DIR=
# browser-runner only. Exact private hostnames allowed for Panda-owned internal services.
BROWSER_ALLOW_PRIVATE_HOSTS=
# Optional browser-runner tuning.
BROWSER_ACTION_TIMEOUT_MS=
BROWSER_SESSION_IDLE_TTL_MS=
BROWSER_SESSION_MAX_AGE_MS=

# Default chat config
# Use a canonical selector like `openai-codex/gpt-5.4` or a small alias like `gpt` / `opus`.
DEFAULT_MODEL=anthropic-oauth/claude-sonnet-4-5
# Optional default model overrides for synchronous subagents.
WORKSPACE_SUBAGENT_MODEL=
MEMORY_SUBAGENT_MODEL=
BROWSER_SUBAGENT_MODEL=

# Optional live smoke / opt-in E2E overrides
# Disposable database used by `panda smoke` and `pnpm test:live`.
TEST_DATABASE_URL=postgresql:///panda_test
# Optional live-test model override. Falls back to the agent's normal default when empty.
TEST_MODEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_OAUTH_TOKEN=
OPENAI_MODEL=gpt-5.1
OPENAI_CODEX_MODEL=gpt-5.4

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_OAUTH_TOKEN=
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_MODEL=claude-sonnet-4-5
PI_CACHE_RETENTION=long

# Optional tools / connectors
BRAVE_API_KEY=
TELEGRAM_BOT_TOKEN=
# Docker stack helper. Set true after the connector account has been linked.
WHATSAPP_ENABLED=
# WhatsApp connector account key. Keep "main" unless you run multiple linked accounts.
WHATSAPP_CONNECTOR_KEY=main
# WhatsApp worker healthcheck port inside the container.
PANDA_WHATSAPP_HEALTH_PORT=8093

# Optional local data dir override
DATA_DIR=

# A2A config
A2A_MAX_MESSAGES_PER_HOUR=60

# Local Wiki.js
WIKI_URL=http://wiki:3000
WIKI_ADMIN_EMAIL=
WIKI_ADMIN_PASSWORD=
WIKI_IMAGE=ghcr.io/requarks/wiki:2
WIKI_PUBLISH_PORT=
WIKI_SITE_URL=
WIKI_SEARCH_DICT_LANGUAGE=simple
WIKI_DB_URL=
# Optional host cert file mounted into Wiki.js as /etc/ssl/certs/panda-postgres-ca.crt.
WIKI_DB_SSL_CERT_FILE=
WIKI_DB_SSL_CA=
