# Core runtime
DATABASE_URL=postgresql:///panda_dev
# Optional override if you want Panda to use a different main connection string.
PANDA_DATABASE_URL=
# Optional read-only connection for the SQL inspection tool.
PANDA_READONLY_DATABASE_URL=

# Default chat config
PANDA_PROVIDER=anthropic-oauth
PANDA_MODEL=claude-sonnet-4-5

# OpenAI
OPENAI_API_KEY=
OPENAI_OAUTH_TOKEN=
OPENAI_MODEL=gpt-5.1
OPENAI_CODEX_MODEL=gpt-5.4

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_OAUTH_TOKEN=
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional tools / connectors
BRAVE_API_KEY=
TELEGRAM_BOT_TOKEN=

# Optional local data dir override
PANDA_DATA_DIR=
